#!/command/with-contenv bash

### Set Defaults
ADMIN_PASS=${ADMIN_PASS:-"admin"}
CLAMAV_HOST=${CLAMAV_HOST:-"clamav"}
CLAMAV_PORT=${CLAMAV_PORT:-"3310"}
DCC_HOST=${DCC_HOST:-"dcc-svc"}
DCC_PORT=${DCC_PORT:-"10045"}
REDIS_HOST=${REDIS_HOST:-"redis"}
REDIS_PORT=${REDIS_PORT:-"6379"}
REDIS_DB=${REDIS_DB:-"7"}
REDIS_TIMEOUT=${REDIS_TIMEOUT:-"1.0"}
LOG_LEVEL=${LOG_LEVEL:-"info"} # error,warning,info,debug
DEBUG_MODULES=${DEBUG_MODULES:-"gpt"}
# NEW DEFAULT: Fallback to system default if no specific server is defined
RSPAMD_DNS_SERVERS=${RSPAMD_DNS_SERVERS:-""} 

log() {
  echo "[init-rspamd] $*"
}

format_debug_modules() {
	local raw="$1"
	local formatted=""
	local item=""

	if [[ "$raw" =~ ^\[.*\]$ ]]; then
		echo "$raw"
		return 0
	fi

	IFS=',' read -ra items <<< "$raw"
	for item in "${items[@]}"; do
		item="${item#${item%%[![:space:]]*}}"
		item="${item%${item##*[![:space:]]}}"
		if [[ -n "$item" ]]; then
			if [[ -n "$formatted" ]]; then
				formatted+=", "
			fi
			formatted+="\"$item\""
		fi
	done

	if [[ -z "$formatted" ]]; then
		echo "[]"
		return 0
	fi

	echo "[$formatted]"
}

copy_rspamd_configs() {
  log "Copying rspamd configuration files"
  cd /assets/rspamd || exit 1
  tar cvf - . | tar xvf - -C /etc/rspamd/
  log "Configuration files copied"
}

configure_worker_controller() {
  sed -i "s/password = .*/password = \"${ADMIN_PASS}\";/" /etc/rspamd/local.d/worker-controller.inc
}

configure_logging() {
  local formatted_debug_modules
  sed -i "s/level = .*/level = \"${LOG_LEVEL}\";/" /etc/rspamd/local.d/logging.inc

  formatted_debug_modules=$(format_debug_modules "$DEBUG_MODULES")
  sed -i "s|debug_modules = .*|debug_modules = ${formatted_debug_modules};|" /etc/rspamd/local.d/logging.inc
}

# NEW FUNCTION: Dynamically injection configuration block for DNS Lookups
configure_dns() {
  if [[ -n "$RSPAMD_DNS_SERVERS" ]]; then
    log "Configuring custom runtime DNS nameservers: $RSPAMD_DNS_SERVERS"
    
    # Ensure local.d directory layer paths exist securely
    mkdir -p /etc/rspamd/local.d
    
    # Inject nameserver arrays into options.inc using a clean schema block
    cat <<EOF > /etc/rspamd/local.d/options.inc
dns {
    nameserver = ["${RSPAMD_DNS_SERVERS}"];
}
EOF
  else
    log "No custom DNS servers defined, defaulting to system resolv.conf settings"
  fi
}

configure_redis() {
  cat <<EOF > /etc/rspamd/local.d/redis.conf
servers = "$REDIS_HOST:$REDIS_PORT";
db = "$REDIS_DB";
write_servers = "$REDIS_HOST:$REDIS_PORT";
read_servers = "$REDIS_HOST:$REDIS_PORT";
timeout = $REDIS_TIMEOUT;
EOF
}

configure_antivirus() {
  sed -i "s/servers = .*/servers = \"${CLAMAV_HOST}:${CLAMAV_PORT}\";/" /etc/rspamd/local.d/antivirus.conf
}

configure_dcc() {
  sed -i "s/servers = .*/servers = \"${DCC_HOST}:${DCC_PORT}\";/" /etc/rspamd/local.d/dcc.conf
}

cleanup_old_cache() {
  log "Cleaning up cache files older than 7 days"
  if [ -d /var/lib/rspamd ]; then
    find /var/lib/rspamd -type f \( -mtime +7 -o -name "*.hs" -o -name "*.map" -o -name "*.hsmc" -o -name "*.hsmp" -o -name "*.unser" \) -delete 2>/dev/null
    log "Cache cleanup completed"
  fi
}

setup_persistent_storage() {
  if [ ! -d /run/rspamd ]; then
    mkdir -p /run/rspamd
  fi

  chown -R rspamd:rspamd /var/lib/rspamd /etc/rspamd /run/rspamd

  mkdir -p /tmp/state
  touch /tmp/state/rspamd-init
}

main() {
  copy_rspamd_configs
  configure_worker_controller
  configure_logging
  configure_dns          # ACTIVATED: Run DNS generation after file copy step executions
  configure_redis
  configure_antivirus
  configure_dcc
  cleanup_old_cache
  setup_persistent_storage

  log "rspamd modifications completed"
}

main "$@"
